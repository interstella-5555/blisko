{
  "name": "@repo/api",
  "description": "Blisko API server (Hono + tRPC + Better Auth)",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "dev:production": "bun --env-file=.env.production run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "start": "bun run src/index.ts",
    "test": "bun --bun vitest run",
    "test:watch": "bun --bun vitest",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/migrate.ts",
    "db:check": "drizzle-kit check",
    "db:drop": "drizzle-kit drop",
    "scatter": "bun run scripts/scatter-locations-db.ts",
    "scatter:production": "bun --env-file=.env.production run scripts/scatter-locations-db.ts",
    "seed:slo": "bun run scripts/seed-slo-targets.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "catalog:",
    "@better-auth/expo": "catalog:",
    "@hono/node-server": "^1.19.9",
    "@hono/trpc-server": "^0.3.0",
    "@repo/db": "workspace:*",
    "@repo/shared": "workspace:*",
    "@trpc/server": "catalog:",
    "ai": "catalog:",
    "better-auth": "catalog:",
    "bullmq": "catalog:",
    "date-fns": "catalog:",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "catalog:",
    "expo-server-sdk": "^6.0.0",
    "hono": "^4.5.0",
    "ms": "catalog:",
    "pg": "^8.17.2",
    "postgres": "catalog:",
    "prom-client": "^15.1.3",
    "resend": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/ms": "catalog:",
    "@types/node": "^20.14.0",
    "better-call": "1.3.2",
    "tsx": "^4.16.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
