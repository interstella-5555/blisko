{
  "name": "@repo/api",
  "description": "Blisko API server (Hono + tRPC + Better Auth)",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "dev:production": "bun --env-file=.env.production run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "start": "bun run src/index.ts",
    "test": "bun --bun vitest run",
    "test:watch": "bun --bun vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "scatter": "bun run scripts/scatter-locations-db.ts",
    "scatter:production": "bun --env-file=.env.production run scripts/scatter-locations-db.ts",
    "seed:slo": "bun run scripts/seed-slo-targets.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.29",
    "@better-auth/expo": "^1.5.4",
    "@hono/node-server": "^1.19.9",
    "@hono/trpc-server": "^0.3.0",
    "@repo/shared": "workspace:*",
    "@trpc/server": "^11.0.0-rc.0",
    "ai": "^6.0.86",
    "better-auth": "^1.5.4",
    "bullmq": "^5.69.2",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "expo-server-sdk": "^6.0.0",
    "hono": "^4.5.0",
    "ms": "^2.1.3",
    "pg": "^8.17.2",
    "postgres": "^3.4.0",
    "prom-client": "^15.1.3",
    "resend": "^6.8.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/ms": "^2.1.0",
    "@types/node": "^20.14.0",
    "better-call": "1.3.2",
    "tsx": "^4.16.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  }
}
