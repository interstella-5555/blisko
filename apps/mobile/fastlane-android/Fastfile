require "json"

default_platform(:android)

# Expo's prebuild-generated android/app/build.gradle only has a `debug` signingConfig
# and the `release` buildType reuses the debug keystore. We override signing via
# android.injected.signing.* properties so Gradle signs the release AAB with the
# real upload keystore read from env vars. Without this override Play Console
# rejects the AAB because it's signed with the debug key.

platform :android do
  desc "Build AAB and upload to Play Console internal track as draft"
  lane :deploy_internal do
    # Generate release notes for Play Console before uploading. Supply reads the
    # file at metadata/android/<locale>/changelogs/<versionCode>.txt — we write
    # it dynamically so the notes always reflect the actual build number
    # (GITHUB_RUN_NUMBER) and versionName (from apps/mobile/app.json). At runtime
    # this Fastfile lives in apps/mobile/android/fastlane/, so app.json is two
    # levels up (apps/mobile/app.json), not one.
    version_code = ENV.fetch("GITHUB_RUN_NUMBER", "1")
    version_name = JSON.parse(File.read(File.expand_path("../../app.json", __dir__))).dig("expo", "version")
    changelog_dir = File.expand_path("metadata/android/pl-PL/changelogs", __dir__)
    FileUtils.mkdir_p(changelog_dir)
    File.write(
      File.join(changelog_dir, "#{version_code}.txt"),
      "Blisko #{version_name} (#{version_code}) — usprawnienia, poprawki błędów i drobne ulepszenia UI.",
    )

    keystore_path = File.expand_path("../app/upload.keystore", __dir__)
    gradle(
      task: "bundle",
      build_type: "Release",
      project_dir: ".",
      properties: {
        "android.injected.signing.store.file" => keystore_path,
        "android.injected.signing.store.password" => ENV.fetch("ANDROID_KEYSTORE_PASSWORD"),
        "android.injected.signing.key.alias" => ENV.fetch("ANDROID_KEY_ALIAS"),
        "android.injected.signing.key.password" => ENV.fetch("ANDROID_KEY_PASSWORD"),
      },
    )
    # release_status: "draft" until Google Play exits the "draft app" state for
    # this app. The API rejects "completed" on a draft app (error: "Only releases
    # with status draft may be created on draft app") — even for the internal
    # track. Exiting draft app requires completing the full Store Listing
    # (icon, feature graphic, screenshots, descriptions) plus a review submit.
    # Until that's done, CI uploads a draft AAB and the release is promoted to
    # testers with a manual "Promuj wersję" click in Play Console. Flip back to
    # "completed" once Google review clears the draft state.
    upload_to_play_store(
      track: "internal",
      aab: "app/build/outputs/bundle/release/app-release.aab",
      release_status: "draft",
      metadata_path: File.expand_path("metadata", __dir__),
      skip_upload_metadata: true,
      skip_upload_changelogs: false,
      skip_upload_images: true,
      skip_upload_screenshots: true,
    )
  end
end
