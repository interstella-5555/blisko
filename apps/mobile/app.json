{
  "expo": {
    "name": "Blisko",
    "slug": "blisko",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "blisko",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF7F2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.blisko.app",
      "icon": {
        "light": "./assets/icon.png",
        "dark": "./assets/icon-dark.png"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Blisko potrzebuje dostępu do lokalizacji, aby pokazać osoby w Twojej okolicy.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Blisko potrzebuje dostępu do lokalizacji, aby powiadamiać Cię o osobach w okolicy.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.blisko.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Blisko potrzebuje dostępu do lokalizacji, aby pokazywać osoby w okolicy."
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "34d895cd-60a0-4c82-affe-7c6fa2b963ee"
      }
    },
    "owner": "random-solutions"
  }
}
