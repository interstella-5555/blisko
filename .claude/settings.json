{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/protect-branches.sh",
            "statusMessage": "Checking branch protection rules..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/enforce-branch-from-default.sh",
            "statusMessage": "Checking branch creation rules..."
          }
        ]
      }
    ]
  }
}
