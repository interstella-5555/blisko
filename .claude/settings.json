{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/protect-branches.sh",
            "statusMessage": "Checking branch protection rules..."
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/enforce-branch-from-default.sh",
            "statusMessage": "Checking branch creation rules..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"ARCHITECT: Before planning or implementing, read relevant architecture docs (docs/architecture/) and state which you consulted. After implementation, run /architecture-update before PR. During code review, run /architecture-review alongside /code-review.\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
